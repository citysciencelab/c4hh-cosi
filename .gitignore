# Masterportal is now VENDORED into this repo (self-contained), not a separate
# checkout. Its source is tracked under masterportal/; generated dirs are ignored
# by the nested .gitignore files there (node_modules, build, dist, coverage,
# portal/cosi/tools/.cache). The belt-and-suspenders rules below cover the rest.
# Upstream provenance + sync procedure: provenance/README.md and Readme.md.

# Dependencies / build output (safety net — also covered by masterportal/.gitignore)
node_modules/
dist/
build/
coverage/

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/

# Local env overrides (committed examples: .env.example, valhalla/.env.example)
.env
valhalla/.env
