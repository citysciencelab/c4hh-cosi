# Include your project-specific ignores in this file
# Read about how to use .gitignore: https://help.github.com/articles/ignoring-files


*.sass-cache
.DS_Store
.env
.idea
.vscode
.history
/jsdoc
/docHtml
/nbproject/
styleguide
.history

# addons/ is VENDORED into this repo (self-contained) — do NOT ignore it.
# Upstream ignores `addons/*` (treats addons as externally supplied); we track
# the source instead. node_modules under addons/ stays ignored via addons/.gitignore.

bowerupdate.log
build
coverage
ci_scripts
css/bootstrap.css
css/modules.css

dist

devtools/certificate/*.key
devtools/certificate/*.pem
devtools/certificate/*.csr

examples*

examples.zip
portal/master

jshintrc
lgv-config
masterportalapi
node_modules
portalconfigs
temp

debug.log
devtools/proxyconf.json
devtools/securedServices.js
lintfixed.html
npm-debug.log

# ignore all dev portals except the four standard portals
/portal/*
!/portal/basic
!/portal/master
!/portal/auto
!/portal/layer
# …and the COSI portalconfig, which is VENDORED here so the Docker/Dokploy build
# is self-contained (it produces dist/cosi/). Source of truth + history:
# provenance/portal-cosi.bundle. Without this the build has no /cosi/ → 404.
!/portal/cosi


# Ignore mkdocs build dir
site/*

# Ignore Python virtual environment
.venv/*

html
