# Copy to `.env` and adjust. docker-compose.yml reads these automatically.

# ── Routing graph (OSM) ──────────────────────────────────────────────────────
# OSM extract(s) to build the routing graph from (Geofabrik). Space-separated
# URLs are merged into one graph (docker-compose passes them as tile_urls).
#
# Default = Hamburg city-state: light + fast for local dev, and the validated
# default for transit (see the GTFS section — the public-transport feed is
# filtered to this extract's polygon). Transit coverage is then Hamburg-city only.
OSM_EXTRACT_URL=https://download.geofabrik.de/europe/germany/hamburg-latest.osm.pbf
#
# ── FULL HVV COVERAGE (server/CSL build) ──
# Hamburg is tightly interconnected with its hinterland, so for the complete HVV
# network (suburban S-Bahn / regional rail to Pinneberg, Norderstedt, Stade,
# Lübeck, …) the graph must span the whole catchment, NOT just the city. Two
# changes, together (one without the other won't help):
#   1. Extend the extract to the catchment states (below), and
#   2. set GTFS_BOUNDARY_POLY= (empty) in the GTFS section so no stops are clipped.
# This is a HEAVY build — many GB download + lots of RAM/disk/time — so run it on
# the CSL server, not a laptop (see Readme.md "Resource needs"). Uncomment ONE:
#
# (a) The HVV catchment as the requested states (most of N+central Germany):
# OSM_EXTRACT_URL="https://download.geofabrik.de/europe/germany/hamburg-latest.osm.pbf https://download.geofabrik.de/europe/germany/schleswig-holstein-latest.osm.pbf https://download.geofabrik.de/europe/germany/mecklenburg-vorpommern-latest.osm.pbf https://download.geofabrik.de/europe/germany/niedersachsen-latest.osm.pbf https://download.geofabrik.de/europe/germany/brandenburg-latest.osm.pbf https://download.geofabrik.de/europe/germany/sachsen-anhalt-latest.osm.pbf https://download.geofabrik.de/europe/germany/berlin-latest.osm.pbf https://download.geofabrik.de/europe/germany/bremen-latest.osm.pbf https://download.geofabrik.de/europe/germany/hessen-latest.osm.pbf"
#
# (b) Or simply all of Germany — fewer moving parts, similar cost to (a):
# OSM_EXTRACT_URL=https://download.geofabrik.de/europe/germany-latest.osm.pbf

# ── Public transport (GTFS) ──────────────────────────────────────────────────
# HVV timetable feed (GTFS). scripts/fetch-gtfs.sh downloads + unzips this into
# gtfs_feeds/hvv/ before the build. Update to the latest release from the Hamburg
# Transparenzportal when a new schedule period is published:
#   https://suche.transparenz.hamburg.de/?q=hvv+fahrplandaten+gtfs
HVV_GTFS_URL=https://daten.transparenz.hamburg.de/Dataport.HmbTG.ZS.Webservice.GetRessource100/GetRessource100.svc/f0073555-962c-4d55-870e-b94bb676ad9d/Upload__hvv_Rohdaten_GTFS_Fpl_20260408.ZIP

# Build the public-transport graph from the GTFS feeds. Set False to build a
# car/bike/foot-only graph (faster, no GTFS needed). Needs >= ~6 GB RAM.
BUILD_TRANSIT=True

# GTFS preparation (scripts/fetch-gtfs.sh) — the raw HVV feed cannot be fed to
# Valhalla as-is, for two reasons (validated 2026-06-26):
#  * It spans ~9 months of service (2.5M stop_times) → the transit+enhance build
#    is enormous and slow. GTFS_TRIM_DAYS clips the calendar to a current window
#    [today, today+N]. Isochrones only need the present schedule. 0 = no trim.
GTFS_TRIM_DAYS=14
#  * It covers the whole metropolitan region, but the Hamburg OSM extract is the
#    city only. Stops outside the road graph make Valhalla ABORT the build
#    (std::bad_array_new_length / "Could not find connection point for in/egress").
#    GTFS_BOUNDARY_POLY filters stops to the extract's Geofabrik polygon (path
#    relative to valhalla/). MUST match OSM_EXTRACT_URL above. Set EMPTY (no
#    value) to disable filtering and keep ALL ~17.6k HVV stops — required for the
#    FULL HVV COVERAGE extract above (a multi-state / Germany graph has a road for
#    every stop, so nothing needs clipping). Leave as hamburg.poly for the default
#    Hamburg-only extract.
GTFS_BOUNDARY_POLY=hamburg.poly

# ── Service ──────────────────────────────────────────────────────────────────
VALHALLA_PORT=8002
SERVER_THREADS=4

# ── Build toggles ────────────────────────────────────────────────────────────
# Admin + timezone DBs: required for correct time-dependent / transit routing.
BUILD_ADMINS=True
BUILD_TIME_ZONES=True
# Elevation tiles: improves bike/foot costing on hilly terrain (extra download).
BUILD_ELEVATION=False
# Set True for a single run to discard existing tiles and rebuild from scratch.
FORCE_REBUILD=False

# Initial-build grace window before the healthcheck reports unhealthy. Bump for
# slow machines / the full Germany build.
HEALTHCHECK_START_PERIOD=3600s

# Image override (default pins the gis-ops community image). The project also
# publishes under ghcr.io/nilsnolde/docker-valhalla/valhalla:latest.
# VALHALLA_IMAGE=ghcr.io/gis-ops/docker-valhalla/valhalla:latest
