# Root COSI stack config. Copy to `.env` and edit as needed.
#
# This file also drives the included Valhalla routing service when there is no
# valhalla/.env (e.g. a fresh clone / Dokploy deploy): the vars in the "Valhalla
# routing" section below are read by valhalla/docker-compose.yml. For the full
# set of routing knobs and the full-HVV-coverage build, see valhalla/.env.example.
# (If valhalla/.env exists, it takes precedence for the Valhalla service.)

# Host port the portal is published on → http://localhost:8080/cosi/
# On Dokploy set this to a FREE port (its Traefik already owns 8080) or routing
# fails with "Bind for 0.0.0.0:8080 failed: port is already allocated".
PORTAL_PORT=8080

# Public hostname for the portal behind Dokploy's Traefik. Set this (e.g.
# cosi.care4.hamburg) in the Dokploy Environment tab and Traefik routes the domain
# to the portal + auto-provisions a Let's Encrypt cert (see the traefik.* labels in
# docker-compose.yml). Leave BLANK for local `docker compose up` (no Traefik).
PORTAL_DOMAIN=

# Base URL the portal uses to reach Valhalla. Default routes through this stack's
# nginx same-origin proxy; only change it to call an external Valhalla directly.
VALHALLA_URL=/valhalla

# Optional registry / style overrides (blank = use the values baked at build time:
# ./services.json, ./rest-services.json, public Hamburg style_v3.json).
LAYER_CONF=
REST_CONF=
STYLE_CONF=

# ── Valhalla routing ─────────────────────────────────────────────────────────
# Read by the included valhalla service when valhalla/.env is absent. Defaults
# here = the validated Hamburg-city build. On a small host this is the safe
# choice; the first deploy still downloads the OSM extract and builds tiles
# (minutes–tens of minutes; tiles persist in the `valhalla_tiles` volume).

# OSM extract to build the routing graph from. Default = Hamburg city-state.
# For full HVV coverage use a wider extract AND set GTFS_BOUNDARY_POLY= (empty);
# that build is HEAVY (many GB, lots of RAM/disk) — see valhalla/.env.example.
OSM_EXTRACT_URL=https://download.geofabrik.de/europe/germany/hamburg-latest.osm.pbf

# Public transport (HVV). True = the gtfs-fetch init container downloads the feed
# and Valhalla builds the transit graph; False = car/bike/foot only (lighter, and
# never depends on the external feed). Needs ~6 GB RAM when True.
BUILD_TRANSIT=True

# HVV GTFS feed — EXPIRES each schedule period; update from the Transparenzportal
# (https://suche.transparenz.hamburg.de/?q=hvv+fahrplandaten+gtfs) when transit
# stops building. A stale URL degrades to no-transit, it won't break the deploy.
HVV_GTFS_URL=https://daten.transparenz.hamburg.de/Dataport.HmbTG.ZS.Webservice.GetRessource100/GetRessource100.svc/f0073555-962c-4d55-870e-b94bb676ad9d/Upload__hvv_Rohdaten_GTFS_Fpl_20260408.ZIP

# GTFS prep: clip calendar to [today, today+N] days; filter stops to the extract
# polygon (MUST match OSM_EXTRACT_URL — set empty for a full-coverage extract).
GTFS_TRIM_DAYS=14
GTFS_BOUNDARY_POLY=hamburg.poly

# Grace window before Valhalla's healthcheck reports unhealthy during the initial
# tile build. Bump for the full-Germany / multi-state build.
HEALTHCHECK_START_PERIOD=3600s
