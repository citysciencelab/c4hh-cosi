{
  "name": "masterportal",
  "private": true,
  "type": "module",
  "author": {
    "name": "Implementierungspartnerschaft Masterportal",
    "email": "info@masterportal.org",
    "url": "https://www.masterportal.org"
  },
  "bugs": "https://bitbucket.org/geowerkstatt-hamburg/masterportal/issues",
  "version": "3.23.0",
  "license": "MIT",
  "description": "The MasterPortal as OpenSource Geoportal",
  "repository": {
    "type": "git",
    "url": "https://bitbucket.org/geowerkstatt-hamburg/masterportal.git"
  },
  "main": "src/masterportal.js",
  "scripts": {
    "prestart": "node devtools/certificate/ensureDevCert.mjs",
    "start": "vite --config devtools/vite.config.js",
    "start:localApi": "cross-env VITE_LOCAL_MASTERPORTALAPI=true vite --config devtools/vite.config.js",
    "startDebug": "vite --debug hmr --debug plugin-transform --config devtools/vite.config.js",
    "test": "rimraf node_modules/.vite && vitest run --config devtools/vitest.config.js",
    "test:watch": "rimraf node_modules/.vite && vitest --config devtools/vitest.config.js --watch",
    "test:silent": "rimraf node_modules/.vite && cross-env SILENT=true vitest  run --config devtools/vitest.config.js",
    "test:silent:watch": "rimraf node_modules/.vite && cross-env SILENT=true vitest --config devtools/vitest.config.js --watch",
    "lint": "eslint \"./**/*.{vue,js}\"",
    "lint:fix": "eslint --fix \"./**/*.{vue,js}\"",
    "migrateConfig": "node devtools/tasks/migrator/migrate.js",
    "build": "node devtools/tasks/viteBuild.js",
    "buildPortal": "vite build --config devtools/vite.config.js && rimraf dist/portal",
    "buildExamples": "cross-env EXAMPLES_ONLY=true vite build --config devtools/vite.config.js --mode production && rimraf dist/portal && rimraf --glob \"dist/examples_*\"",
    "buildJsDoc": "node devtools/tasks/buildJsDoc.js",
    "versionHotfix": "npm version patch && npm run versionLatest && git tag -d lts && git push --tags -f --no-verify",
    "versionMinor": "npm version minor && npm run versionLatest && git tag -d lts && git push --tags -f --no-verify",
    "versionMajor": "npm version major && npm run versionLatest && git tag -d lts && git push --tags -f --no-verify",
    "versionLatest": "git tag latest -f",
    "versionHotfix:all": "npm run versionHotfix && cd addons && npm run versionHotfix && cd .. && cd portalconfigs && npm run versionHotfix && cd ..",
    "versionMinor:all": "npm run versionMinor && cd addons && npm run versionMinor && cd .. && cd portalconfigs && npm run versionMinor && cd ..",
    "versionMajor:all": "npm run versionMajor && cd addons && npm run versionMajor && cd .. && cd portalconfigs && npm run versionMajor && cd ..",
    "prePushHook": "node ./node_modules/@masterportal/mpconfigparser/cli.js docs/User/Portal-Config/config.json.md docs/User/Portal-Config/config.json.de.md && eslint --max-warnings 0 \"./**/*.{vue,js}\" && npm run test",
    "validateDocs": "node devtools/docsValidation/validateDocs.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@masterportal/masterportalapi": "^2.62.0",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.16.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "i18next-vue": "^5.4.0",
    "jsts": "^2.12.1",
    "mqtt": "^5.15.1",
    "object-hash": "^3.0.0",
    "qrcode": "1.5.4",
    "rimraf": "^6.1.3",
    "three": "^0.184.0",
    "url-parse": "^1.5.10",
    "vue": "^3.5.33",
    "vue-datepicker-next": "^1.0.3",
    "vue-matomo": "^4.2.0",
    "vue-multiselect": "3.5.0",
    "vuedraggable": "^4.1.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@geoblocks/print": "^0.7.9",
    "@masterportal/mpconfigparser": "^2.0.0",
    "@sinonjs/fake-timers": "^14.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vitest/ui": "^4.0.16",
    "@vitest/web-worker": "^4.0.16",
    "@vue/compiler-sfc": "3.5.33",
    "@vue/devtools-api": "^8.1.2",
    "@vue/server-renderer": "3.5.33",
    "@vue/test-utils": "^2.4.9",
    "canvas": "^3.2.3",
    "chai": "^6.2.2",
    "child-process-promise": "^2.2.1",
    "cross-env": "^10.1.0",
    "esbuild-loader": "^4.4.3",
    "eslint-plugin-jsdoc": "63.0.1",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-vue": "10.9.1",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "fs-extra": "^11.3.4",
    "globals": "^17.6.0",
    "https-proxy-agent": "^9.0.0",
    "husky": "^9.1.7",
    "jsdoc": "4.0.5",
    "jsdoc-vuejs": "^4.0.0",
    "jsdom": "^29.1.1",
    "jsdom-worker": "^0.3.0",
    "mock-local-storage": "^1.1.24",
    "regenerator-runtime": "^0.14.1",
    "replace-in-file": "8.4.0",
    "resize-observer-polyfill": "^1.5.1",
    "sass": "1.77.2",
    "shelljs": "^0.10.0",
    "sinon": "22.0.0",
    "sinon-chai": "^4.0.1",
    "vite": "^8.0.14",
    "vite-plugin-cp": "^6.0.3",
    "vite-plugin-dynamic-import": "^1.6.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-zip-pack": "^1.2.4",
    "vitest": "^4.0.16",
    "xmlserializer": "^0.6.1"
  },
  "overrides": {
    "@cesium/engine": "npm:dry-uninstall",
    "@cesium/widgets": "npm:dry-uninstall"
  },
  "engines": {
    "node": ">=22.19.0 <23 || >=24 <25",
    "npm": ">=10.9.3 <12"
  }
}
